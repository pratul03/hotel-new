;# API Server
PORT=8080
NODE_ENV=development

# Database
DATABASE_URL=postgresql://airbnb_user:airbnb_password@localhost:5432/airbnb_dev
DATABASE_URL_UNPOOLED=postgresql://airbnb_user:airbnb_password@localhost:5432/airbnb_dev
DB_POOL_MAX=10
DB_POOL_MIN=2

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=30d

# Auth cookies
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_PREFIX=airbnb

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Frontend
FRONTEND_URL=http://localhost:3000

# Email (optional for now)
SMTP_HOST=
SMTP_PORT=
