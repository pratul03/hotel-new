{
  "name": "airbnb-backend",
  "version": "1.0.0",
  "description": "Express backend API for Airbnb clone",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "dev:cluster": "ts-node src/cluster.ts",
    "start:cluster": "node dist/cluster.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "ts-node src/prisma/seed.ts",
    "db:seed-courses": "ts-node src/prisma/seed-courses.ts",
    "loadtest": "artillery run loadtest/load-test.yml",
    "loadtest:report": "artillery run --output loadtest/report.json loadtest/load-test.yml && artillery report loadtest/report.json",
    "cannon": "node loadtest/autocannon-test.js",
    "cannon:quick": "node loadtest/autocannon-test.js quick",
    "cannon:stress": "node loadtest/autocannon-test.js stress",
    "cannon:benchmark": "node loadtest/autocannon-test.js benchmark",
    "test": "jest",
    "lint": "eslint src prisma.config.ts --ext .ts",
    "lint:sonar": "eslint src prisma.config.ts --ext .ts",
    "lint:fix": "eslint src prisma.config.ts --ext .ts --fix"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^2.30.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.7",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.2",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "puppeteer": "^24.39.1",
    "razorpay": "^2.9.2",
    "redis": "^4.6.12",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tslib": "^2.8.1",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@opentelemetry/api": "1.4.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "artillery": "^2.0.30",
    "autocannon": "^8.0.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "pnpm": {
    "overrides": {
      "@opentelemetry/api": "1.4.1"
    }
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
