# ─── Job Supervisor Environment Variables ─────────────────────────────────────

NODE_ENV=development

# PostgreSQL (same DB as the main backend)
DATABASE_URL=postgresql://airbnb_user:airbnb_password@localhost:5432/airbnb_dev

# Redis (same instance as the main backend)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Feature flags
ENABLE_CRON_JOBS=true

# Admin escalation email (used for incident escalation events)
ADMIN_EMAIL=admin@yourdomain.com
