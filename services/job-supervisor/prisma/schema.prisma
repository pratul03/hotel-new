generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique @db.VarChar(255)
  password     String
  name         String   @db.VarChar(255)
  avatar       String?  @db.Text
  role         String   @default("guest") @db.VarChar(50)
  verified     Boolean  @default(false)
  superhost    Boolean  @default(false)
  responseRate Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hotels              Hotel[]
  bookingsAsGuest     Booking[]        @relation("guest")
  reviewsReceived     Review[]         @relation("receivedReviews")
  reviewsSent         Review[]         @relation("sentReviews")
  messagesReceived    Message[]        @relation("receiver")
  messagesSent        Message[]        @relation("sender")
  wishlists           Wishlist[]
  documents           UserDocument[]
  hostVerification    HostVerification?
  notifications       Notification[]
  incidentReports     IncidentReport[]
  supportTickets      SupportTicket[]
  searchHistory       SearchHistory[]

  @@index([email])
  @@index([role])
}

model UserDocument {
  id           String   @id @default(cuid())
  userId       String
  documentType String   @db.VarChar(100)
  docUrl       String   @db.Text
  status       String   @default("pending") @db.VarChar(50)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Hotel {
  id             String   @id @default(cuid())
  ownerId        String
  name           String   @db.VarChar(255)
  description    String?  @db.Text
  location       String   @db.VarChar(500)
  amenities      String   @db.Text @default("[]")
  publicRules    String?  @db.Text
  checkInTime    String   @default("14:00")
  checkOutTime   String   @default("10:00")
  instantBooking Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner        User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rooms        Room[]
  blockedDates BlockedDates[]
  reviews      Review[]

  @@index([ownerId])
}

model Room {
  id         String   @id @default(cuid())
  hotelId    String
  roomType   String   @db.VarChar(100)
  capacity   Int      @default(2)
  maxGuests  Int      @default(2)
  basePrice  Float    @default(0)
  amenities  String   @db.Text @default("[]")
  images     String   @db.Text @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hotel        Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  availability RoomAvailability[]
  blockedDates BlockedDates[]
  wishlists    Wishlist[]

  @@index([hotelId])
}

model Booking {
  id                 String    @id @default(cuid())
  userId             String
  roomId             String
  checkIn            DateTime
  checkOut           DateTime
  status             String    @default("pending") @db.VarChar(50)
  amount             Float
  guestCount         Int       @default(1)
  cancellationPolicy String    @default("moderate") @db.VarChar(50)
  notes              String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  expiresAt          DateTime?

  guest           User             @relation("guest", fields: [userId], references: [id], onDelete: Cascade)
  room            Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  payment         Payment?
  history         BookingHistory[]
  reviews         Review[]
  messages        Message[]
  incidentReports IncidentReport[]

  @@index([userId])
  @@index([roomId])
  @@index([status])
  @@index([expiresAt])
}

model BookingHistory {
  id        String   @id @default(cuid())
  bookingId String
  status    String   @db.VarChar(50)
  changedAt DateTime @default(now())
  updatedBy String   @default("system") @db.VarChar(100)
  notes     String?  @db.Text

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model RoomAvailability {
  id            String   @id @default(cuid())
  roomId        String
  date          DateTime @db.Date
  isAvailable   Boolean  @default(true)
  blockedReason String?  @db.VarChar(255)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@index([roomId, date])
}

model BlockedDates {
  id        String   @id @default(cuid())
  hotelId   String?
  roomId    String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  reason    String   @db.VarChar(255)
  createdAt DateTime @default(now())

  hotel Hotel? @relation(fields: [hotelId], references: [id], onDelete: SetNull)
  room  Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([roomId])
}

model Review {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  bookingId  String
  rating     Int      @default(5)
  comment    String?  @db.Text
  categories String   @db.Text @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  hotelId    String?

  sender   User     @relation("sentReviews", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User     @relation("receivedReviews", fields: [receiverId], references: [id], onDelete: Cascade)
  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  hotel    Hotel?   @relation(fields: [hotelId], references: [id], onDelete: SetNull)

  @@unique([bookingId, senderId])
  @@index([senderId])
  @@index([receiverId])
  @@index([bookingId])
}

model Payment {
  id                String   @id @default(cuid())
  bookingId         String   @unique
  razorpayOrderId   String?  @unique @db.VarChar(255)
  razorpayPaymentId String?  @unique @db.VarChar(255)
  amount            Float
  tax               Float    @default(0)
  serviceFee        Float    @default(0)
  status            String   @default("pending") @db.VarChar(50)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([razorpayOrderId])
  @@index([status])
}

model CancellationPolicy {
  id               String   @id @default(cuid())
  name             String   @unique @db.VarChar(255)
  type             String   @unique @db.VarChar(50)
  refundPercentage Int      @default(100)
  description      String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([type])
}

model Wishlist {
  id      String   @id @default(cuid())
  userId  String
  roomId  String
  addedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  senderUserId   String
  receiverUserId String
  bookingId      String?
  content        String   @db.Text
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sender   User     @relation("sender", fields: [senderUserId], references: [id], onDelete: Cascade)
  receiver User     @relation("receiver", fields: [receiverUserId], references: [id], onDelete: Cascade)
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([senderUserId])
  @@index([receiverUserId])
  @@index([bookingId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @db.VarChar(100)
  content   String   @db.Text
  link      String?  @db.VarChar(500)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model IncidentReport {
  id               String    @id @default(cuid())
  bookingId        String
  reportedByUserId String
  description      String    @db.Text
  status           String    @default("open") @db.VarChar(50)
  resolution       String?   @db.Text
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  booking    Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reportedBy User    @relation(fields: [reportedByUserId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status])
}

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  subject     String   @db.VarChar(255)
  description String   @db.Text
  status      String   @default("open") @db.VarChar(50)
  priority    String   @default("medium") @db.VarChar(50)
  reply       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model SearchHistory {
  id            String    @id @default(cuid())
  userId        String
  queryLocation String    @db.VarChar(500)
  checkIn       DateTime?
  checkOut      DateTime?
  guests        Int       @default(1)
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model HostVerification {
  id                String   @id @default(cuid())
  userId            String   @unique
  accountAge        DateTime @default(now())
  bookingsCompleted Int      @default(0)
  avgRating         Float    @default(0)
  responseRate      Int      @default(0)
  cancellationRate  Int      @default(0)
  status            String   @default("pending") @db.VarChar(50)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model ServiceFeeConfig {
  id          String   @id @default(cuid())
  percentage  Float    @default(13)
  cap         Float    @default(0)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaxConfiguration {
  id            String   @id @default(cuid())
  region        String   @unique @db.VarChar(255)
  taxPercentage Float    @default(5)
  description   String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([region])
}
