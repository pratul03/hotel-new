# ─── Notification Service Environment Variables ─────────────────────────────

NODE_ENV=development

# PostgreSQL (same DB as the main backend)
DATABASE_URL=postgresql://airbnb_user:airbnb_password@localhost:5432/airbnb_dev

# Redis (same instance as the main backend)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_EVENT_CHANNEL=app:v1:events

# ─── Gmail SMTP ──────────────────────────────────────────────────────────────
# Use a Google App Password (not your regular password).
# Enable 2FA then visit: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── App Metadata ─────────────────────────────────────────────────────────────
APP_NAME=My BnB
APP_URL=http://localhost:3001
FROM_EMAIL_NAME=My BnB

# Admin email (escalation alerts)
ADMIN_EMAIL=admin@yourdomain.com
